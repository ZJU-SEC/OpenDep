{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resolver-spec/request.schema.json",
  "title": "resolving Specification Request",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "trace_id",
    "command",
    "ecosystem"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "enum": [
        "resolve",
        "list",
        "health",
        "capabilities"
      ]
    },
    "ecosystem": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "return_raw": {
          "type": "boolean"
        },
        "platform": {
          "type": "object",
          "properties": {
            "os": {
              "type": "string"
            },
            "cpu": {
              "type": "string"
            },
            "libc": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}